{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Glob",
      "Grep",
      "Bash(*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:readthedocs.io)",
      "WebFetch(domain:readthedocs.org)",
      "WebFetch(domain:numpy.org)",
      "WebFetch(domain:scipy.org)",
      "WebFetch(domain:pandas.pydata.org)",
      "WebFetch(domain:pytorch.org)",
      "WebFetch(domain:docs.jax.dev)",
      "WebFetch(domain:huggingface.co)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:biopython.org)",
      "WebFetch(domain:mdanalysis.org)",
      "WebFetch(domain:biotite-python.org)",
      "WebFetch(domain:gemmi.readthedocs.io)",
      "WebFetch(domain:phenix-online.org)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(npm install *)",
      "Bash(gh pr *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh issue edit *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git checkout main)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Read(//etc/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Edit(//etc/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claudeception-activator.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/review-loop.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/review-loop.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "obsidian@obsidian-skills": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "effortLevel": "high"
}
